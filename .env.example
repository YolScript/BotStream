# ==== Discord ====
DISCORD_TOKEN=
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
# Optionnel: ID d'un serveur de test pour un deploy instantane des commandes slash (sinon deploy global, ~1h de propagation)
DEV_GUILD_ID=
# URL publique du panel (callback OAuth2 = <PUBLIC_URL>/auth/discord/callback)
PUBLIC_URL=http://localhost:3000
SESSION_SECRET=change-moi-en-une-longue-chaine-aleatoire
# Optionnel : ID Discord du seul compte pouvant voir le panel admin (/admin)
SUPER_ADMIN_DISCORD_ID=

# ==== Twitch (https://dev.twitch.tv/console/apps) ====
# Redirect URL a enregistrer sur l'appli Twitch : <PUBLIC_URL>/auth/twitch/callback
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=

# ==== YouTube (Google Cloud Console -> YouTube Data API v3) ====
YOUTUBE_API_KEY=

# ==== Google OAuth2 (bouton "Se connecter avec YouTube" pour lier une chaine) ====
# Google Cloud Console > APIs & Services > Credentials > Create OAuth Client ID (Web application)
# Redirect URI a enregistrer : <PUBLIC_URL>/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ==== Serveur web ====
PORT=3000

# ==== Polling (ms) ====
TWITCH_POLL_INTERVAL_MS=20000
YOUTUBE_POLL_INTERVAL_MS=90000
TIKTOK_POLL_INTERVAL_MS=90000
SUBSCRIPTION_CHECK_INTERVAL_MS=300000
ROLE_SYNC_INTERVAL_MS=600000
