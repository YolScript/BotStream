# ==== Discord ====
DISCORD_TOKEN=
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
# Optionnel: ID d'un serveur de test pour un deploy instantane des commandes slash (sinon deploy global, ~1h de propagation)
DEV_GUILD_ID=
# URL publique du panel (callback OAuth2 = <PUBLIC_URL>/auth/discord/callback)
PUBLIC_URL=http://localhost:3000
SESSION_SECRET=change-moi-en-une-longue-chaine-aleatoire

# ==== Twitch (https://dev.twitch.tv/console/apps) ====
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=

# ==== YouTube (Google Cloud Console -> YouTube Data API v3) ====
YOUTUBE_API_KEY=

# ==== Serveur web ====
PORT=3000

# ==== Polling (ms) ====
TWITCH_POLL_INTERVAL_MS=60000
YOUTUBE_POLL_INTERVAL_MS=90000
TIKTOK_POLL_INTERVAL_MS=90000
SUBSCRIPTION_CHECK_INTERVAL_MS=300000
