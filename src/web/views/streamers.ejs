<%- include('partials/head') %>

<a class="breadcrumb" href="/dashboard/<%= guild.id %>">&larr; <%= guild.name %></a>
<h1>Streamers suivis</h1>

<% if (error) { %><p class="flash flash-error"><%= error %></p><% } %>
<% if (connected) { %><p class="flash flash-ok">Compte <%= connected %> connecte et ajoute au suivi.</p><% } %>

<div class="card">
  <h2>Connecter une plateforme</h2>
  <p class="muted">Connecte-toi avec le compte du streamer a suivre : le pseudo et l'avatar sont recuperes automatiquement, aucune saisie manuelle.</p>

  <div class="connect-row">
    <% if (twitchEnabled) { %>
      <a class="connect-tile tw" href="/auth/twitch?guildId=<%= guild.id %>">
        <div class="badge-icon bg-twitch">T</div>
        <strong>Twitch</strong>
        <span>Se connecter avec Twitch</span>
      </a>
    <% } else { %>
      <div class="connect-tile tw" style="opacity: 0.5">
        <div class="badge-icon bg-twitch">T</div>
        <strong>Twitch</strong>
        <span>Non configure (TWITCH_CLIENT_ID manquant)</span>
      </div>
    <% } %>

    <% if (googleEnabled) { %>
      <a class="connect-tile yt" href="/auth/google?guildId=<%= guild.id %>">
        <div class="badge-icon bg-youtube">Y</div>
        <strong>YouTube</strong>
        <span>Se connecter avec Google</span>
      </a>
    <% } else { %>
      <div class="connect-tile yt" style="opacity: 0.5">
        <div class="badge-icon bg-youtube">Y</div>
        <strong>YouTube</strong>
        <span>Non configure (GOOGLE_CLIENT_ID manquant)</span>
      </div>
    <% } %>

    <div class="connect-tile tt" style="opacity: 0.5">
      <div class="badge-icon bg-tiktok">TT</div>
      <strong>TikTok</strong>
      <span>Pas de connexion officielle : ajoute le pseudo ci-dessous</span>
    </div>
  </div>

  <form method="post" action="/dashboard/<%= guild.id %>/streamers/add">
    <input type="hidden" name="platform" value="tiktok" />
    <label>Pseudo TikTok
      <input type="text" name="username" required placeholder="ex: charlidamelio" />
    </label>
    <button class="btn btn-tiktok" type="submit">Ajouter ce compte TikTok</button>
  </form>
</div>

<table class="table">
  <thead>
    <tr><th>Statut</th><th>Plateforme</th><th>Nom</th><th></th></tr>
  </thead>
  <tbody>
    <% streamers.forEach(function(s) { %>
      <tr>
        <td><span class="badge <%= s.is_live ? 'badge-ok' : 'badge-off' %>"><%= s.is_live ? 'EN LIVE' : 'Hors ligne' %></span></td>
        <td><span class="platform-badge platform-<%= s.platform %>"><span class="dot"></span><%= s.platform %></span></td>
        <td><%= s.display_name || s.username %></td>
        <td>
          <form method="post" action="/dashboard/<%= guild.id %>/streamers/<%= s.id %>/delete">
            <button class="btn btn-danger btn-sm" type="submit">Retirer</button>
          </form>
        </td>
      </tr>
    <% }) %>
    <% if (streamers.length === 0) { %>
      <tr><td colspan="4" class="muted">Aucun streamer suivi.</td></tr>
    <% } %>
  </tbody>
</table>

<%- include('partials/foot') %>
