<%- include('partials/head') %>

<div class="login-wrap">
  <img class="login-logo" src="/img/logo.png" alt="" />
  <h1>BotStream</h1>
  <p class="tagline">Notifications de live Twitch / YouTube / TikTok sur Discord, avec gestion des abonnements et des roles.</p>

  <div class="steps">
    <div class="step">
      <div class="step-num">1</div>
      <div class="step-body">
        <strong>Connexion avec Discord</strong>
        <span>Identifie-toi pour retrouver les serveurs que tu geres.</span>
      </div>
    </div>
    <div class="step">
      <div class="step-num">2</div>
      <div class="step-body">
        <strong>Inviter le bot</strong>
        <span>Ajoute BotStream sur ton serveur Discord (un clic depuis le dashboard).</span>
      </div>
    </div>
    <div class="step">
      <div class="step-num">3</div>
      <div class="step-body">
        <strong>Configurer</strong>
        <span>Connecte tes comptes Twitch/YouTube, choisis les salons, gere les abonnements.</span>
      </div>
    </div>
  </div>

  <a class="btn btn-discord btn-block" href="/auth/discord">Se connecter avec Discord</a>

  <a class="topgg-badge" href="https://top.gg/bot/1449858112054886442" target="_blank" rel="noopener">
    <img src="https://top.gg/api/widget/1449858112054886442.svg" alt="BotStream sur top.gg" />
  </a>
</div>

<%- include('partials/foot') %>
